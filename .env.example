# ================================================================
# Railway Project — переменные окружения для production
# Скопируйте этот файл в .env и заполните значения
# ================================================================

# Домен (FQDN без https://)
# Пример: myapp.example.com
DOMAIN=yourdomain.com

# Email для Let's Encrypt (получит уведомления об истечении сертификата)
CERTBOT_EMAIL=devops@example.com

# ----------------------------------------------------------------
# PostgreSQL — внешняя база данных
# Формат: postgresql://USER:PASSWORD@HOST:PORT/DBNAME
# ----------------------------------------------------------------
DATABASE_URL=postgresql://username:password@db-host:5432/logistics_service

# ----------------------------------------------------------------
# JWT
# Сгенерировать: openssl rand -hex 32
# ----------------------------------------------------------------
JWT_SECRET=REPLACE_WITH_STRONG_SECRET_64_CHARS

# ----------------------------------------------------------------
# Учётная запись администратора (первичная инициализация)
# ----------------------------------------------------------------
ADMIN_LOGIN=admin
ADMIN_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
